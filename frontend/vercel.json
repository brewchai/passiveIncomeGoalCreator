{
    "rewrites": [
        {
            "source": "/about",
            "destination": "/about.html"
        },
        {
            "source": "/privacy",
            "destination": "/privacy.html"
        },
        {
            "source": "/terms",
            "destination": "/terms.html"
        },
        {
            "source": "/contact",
            "destination": "/contact.html"
        },
        {
            "source": "/blog",
            "destination": "/blog.html"
        },
        {
            "source": "/blog/:slug",
            "destination": "/blog/posts/:slug/index.html"
        },
        {
            "source": "/tools/geo-arbitrage",
            "destination": "/tools/geo-arbitrage/index.html"
        },
        {
            "source": "/tools/geo-arbitrage/",
            "destination": "/tools/geo-arbitrage/index.html"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "redirects": [
        {
            "source": "/",
            "destination": "/blog",
            "permanent": false
        },
        {
            "source": "/blog/40k-debt-to-1m-at-33",
            "destination": "/blog/40k-debt-to-coast-fire-at-33",
            "permanent": true
        }
    ]
}
